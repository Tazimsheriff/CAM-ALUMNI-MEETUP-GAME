# GEMINI_API_KEY: Required for Gemini AI features (e.g. meme generator, smart insights).
# Configure this with your Google Gemini API Key.
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# APP_URL: The hosting URL of the application.
# Used for absolute URL resolution, self-references, and sharing.
APP_URL="http://localhost:3000"

# SUPABASE CONFIGURATION:
# Get these credentials from your Supabase Project Settings -> API.
VITE_SUPABASE_URL="YOUR_SUPABASE_URL"
VITE_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"

